{% schema %}
{
  "name": "Luxury Overlap Section",
  "settings": [
    { "type": "image_picker", "id": "main_image", "label": "Main Image" },

    { "type": "image_picker", "id": "overlay_image", "label": "Overlay Image" },

    { "type": "video_url", "id": "video_url", "label": "Overlay Video URL (YouTube/Vimeo)", "accept": ["youtube", "vimeo"] },

    { "type": "text", "id": "subheading", "label": "Subheading", "default": "WELCOME TO AURUM JEWELS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "FINEST JEWELRY COLLECTION" },
    { "type": "textarea", "id": "description", "label": "Description" },

    { "type": "text", "id": "button_text", "label": "Button Text", "default": "VIEW COLLECTION" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Luxury Overlap Section" }
  ]
}
{% endschema %}

<style>
.lux-section {
  background: #fff;
  padding: 80px 5%;
}

.lux-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1300px;
  margin: auto;
  gap: 80px;
}

.lux-images {
  position: relative;
  width: 50%;
}

.lux-main-img {
  width: 76%;
}

.lux-overlay-box {
  position: absolute;
  top: 50%;
  left: 85%;
  transform: translate(-50%, -50%);
  width: 48%;
  cursor: pointer;
}

.lux-overlay-box img {
  width: 100%;
  display: block;
}

.play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60px;
  height: 60px;
  border-radius: 50%;
  border: 1px solid #fff;
}

.play-btn:after {
  content: '';
  position: absolute;
  left: 23px;
  top: 18px;
  border-left: 15px solid #fff;
  border-top: 10px solid transparent;
  border-bottom: 10px solid transparent;
}

/* POPUP */
.video-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.8);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.video-popup iframe {
  width: 80%;
  height: 60%;
}

.video-popup.active {
  display: flex;
}

/* RIGHT CONTENT same as before */
.lux-content { width: 50%; padding-left: 110px}
.lux-subheading { font-family: DM Sans; font-weight: 600; font-size: 16px; letter-spacing: 10%; text-transform: uppercase; color: #B76979; }
.lux-heading { font-family: Gotu; font-weight: 400; font-size: 30px; line-height: 40px; letter-spacing: 10%; text-transform: uppercase; margin: 15px 0; color: #3F3F3F; }
.lux-description { font-family: DM Sans; font-weight: 400; font-size: 16px;  margin-bottom: 60px; }
.lux-btn { font-family: DM Sans; font-weight: 700; font-size: 14px; text-transform: uppercase; background:#2F4B4C; color:#fff; padding:15px 35px; text-decoration:none; }

@media(max-width:768px){
  .lux-container { flex-direction: column; }
  .lux-images, .lux-content { width:100%; }
  .lux-overlay-box {
    position: relative;
    transform: none;
    left: 0;
    top: 0;
    margin-top: 20px;
  }
}
</style>

<div class="lux-section">
  <div class="lux-container">

    <!-- LEFT -->
    <div class="lux-images">

      {% if section.settings.main_image != blank %}
        <img class="lux-main-img" src="{{ section.settings.main_image | image_url: width: 900 }}">
      {% endif %}

      <div class="lux-overlay-box" onclick="openVideo()">
        
        {% if section.settings.overlay_image != blank %}
          <img src="{{ section.settings.overlay_image | image_url: width: 500 }}">
        {% endif %}

        {% if section.settings.video_url != blank %}
          <div class="play-btn"></div>
        {% endif %}

      </div>

    </div>

    <!-- RIGHT -->
    <div class="lux-content">
      <div class="lux-subheading">{{ section.settings.subheading }}</div>
      <div class="lux-heading">{{ section.settings.heading }}</div>
      <div class="lux-description">{{ section.settings.description }}</div>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_link }}" class="lux-btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

  </div>
</div>

<!-- VIDEO POPUP -->
{% if section.settings.video_url != blank %}
<div class="video-popup" id="videoPopup" onclick="closeVideo()">
  <iframe 
    src="{{ section.settings.video_url | replace: 'watch?v=', 'embed/' }}"
    frameborder="0"
    allowfullscreen>
  </iframe>
</div>
{% endif %}

<script>
function openVideo(){
  document.getElementById('videoPopup').classList.add('active');
}

function closeVideo(){
  document.getElementById('videoPopup').classList.remove('active');
}
</script>
