<style>
.testimonial-section {
  padding: 80px 20px;
  text-align: center;
  background: #fff;
}

.testimonial-section h4 {
  font-family: DM Sans;
  color: #B76979;
  font-size: 16px;
  margin-bottom: 10px;
  letter-spacing: 10%;
  text-transform: uppercase;
  font-weight: 600;
}

.testimonial-section h2 {
  font-family: Gotu;
  font-size: 30px;
  letter-spacing: 2px;
  margin-bottom: 40px;
  font-weight: 400;
  letter-spacing: 10%;
  text-transform: uppercase;
  color: #3F3F3F;
}

.testimonial-wrapper {
  display: flex;
  justify-content: center;
  gap: 100px;
  flex-wrap: wrap;
}

.testimonial-item {
  max-width: 350px;
}

.stars {
  color: #B6697A;
  margin-bottom: 15px;
  font-size: 23px;
  font-weight: 800;
  letter-spacing: -2.7px;
}

.testimonial-text {
  font-family: DM Sans;
  font-weight: 400;
  font-size: 18px;
  color: #3F3F3F;
  margin-bottom: 30px;
}

.testimonial-avatar img {
  display: block;
  margin: 0 auto;
  width: 60px;
  height: 60px;
  border-radius: 50%;
}

.testimonial-name {
  font-size: 13px;
  color: #333;
  margin-top: 10px;
}
</style>

<div class="testimonial-section">
  <h4>CLIENT TESTIMONIALS</h4>
  <h2>WHAT OUR CLIENTS SAY...</h2>

  <div class="testimonial-wrapper">
    {% for block in section.blocks %}
      <div class="testimonial-item">
        
        <div class="stars">
          {% for i in (1..block.settings.stars) %}
            ★
          {% endfor %}
        </div>

        <div class="testimonial-text">
          {{ block.settings.text }}
        </div>

        <div class="testimonial-avatar">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 100 }}">
          {% endif %}
        </div>

        <div class="testimonial-name">
          {{ block.settings.name }}
        </div>

      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "Customer Name"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Write something nice about your product."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Image"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}